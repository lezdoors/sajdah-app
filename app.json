{
  "expo": {
    "name": "Sajdah",
    "slug": "sajdah",
    "version": "1.0.1",
    "description": "Your spiritual companion — prayer times, Quran, Qibla compass, and daily inspiration. From the heart.",
    "scheme": "sajdah",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/mosque-night.png",
      "resizeMode": "cover",
      "backgroundColor": "#0A1A14"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.menanadigital.sajdah",
      "buildNumber": "1",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Sajdah needs your location to calculate accurate prayer times and Qibla direction.",
        "NSMotionUsageDescription": "Sajdah uses the compass sensor to determine the Qibla direction.",
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": [
          "remote-notification"
        ]
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0A1628",
        "foregroundImage": "./assets/icon.png"
      },
      "package": "com.lezdoors.sajdah",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Sajdah needs your location to calculate accurate prayer times and Qibla direction."
        }
      ],
      "expo-sensors",
      [
        "expo-notifications",
        {
          "sounds": [
            "./assets/audio/notif/adhan-default-notif.mp3",
            "./assets/audio/notif/adhan-makkah-notif.mp3",
            "./assets/audio/notif/adhan-madinah-notif.mp3",
            "./assets/audio/notif/adhan-alaqsa-notif.mp3",
            "./assets/audio/notif/adhan-alafasy-notif.mp3",
            "./assets/audio/notif/adhan-alafasy2-notif.mp3",
            "./assets/audio/notif/adhan-turkish-notif.mp3",
            "./assets/audio/notif/adhan-nafees-notif.mp3",
            "./assets/audio/notif/adhan-zahrani-notif.mp3"
          ]
        }
      ],
      "expo-av"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "196afaeb-405e-491c-814f-b2a5818a77ce"
      }
    },
    "owner": "lezdoors",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/196afaeb-405e-491c-814f-b2a5818a77ce"
    }
  }
}
